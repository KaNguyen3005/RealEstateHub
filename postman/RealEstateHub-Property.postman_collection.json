        {
          "name": "Login Seller 1",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{seller1Email}}\",\n  \"password\": \"{{seller1Password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login the first demo seller and store seller1AccessToken."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Success flag is true', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set('seller1AccessToken', json.data.accessToken);",
                  "}",
                  "if (json?.data?.user?._id) {",
                  "  pm.collectionVariables.set('seller1UserId', json.data.user._id);",
                  "}"
                ]
              }
            }
          ]
