    {
      "name": "Public",
      "item": [
        {
          "name": "Get Properties List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties?limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "properties"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Fetch approved properties with pagination and seed comparison IDs from the result."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Success flag is true', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "const items = Array.isArray(json?.data?.items) ? json.data.items : [];",
                  "pm.test('Items is an array', function () {",
                  "  pm.expect(items).to.be.an('array');",
                  "});",
                  "",
                  "const ids = items.map((item) => String(item?._id || '')).filter(Boolean);",
                  "if (ids.length > 0) {",
                  "  pm.collectionVariables.set('publicPropertyId', ids[0]);",
                  "}",
                  "if (ids.length > 0) {",
                  "  pm.collectionVariables.set('compareIds', ids.slice(0, 3).join(','));",
                  "}",
                  "",
                  "const seller1Email = pm.collectionVariables.get('seller1Email');",
                  "const seller2Email = pm.collectionVariables.get('seller2Email');",
                  "const seller1Item = items.find((item) => item?.ownerId?.email === seller1Email);",
                  "const seller2Item = items.find((item) => item?.ownerId?.email === seller2Email);",
                  "",
                  "if (seller1Item?._id) {",
                  "  pm.collectionVariables.set('sellerOnePropertyId', String(seller1Item._id));",
                  "} else if (ids[0]) {",
                  "  pm.collectionVariables.set('sellerOnePropertyId', ids[0]);",
                  "}",
                  "if (seller2Item?._id) {",
                  "  pm.collectionVariables.set('sellerTwoPropertyId', String(seller2Item._id));",
                  "} else if (ids[1]) {",
                  "  pm.collectionVariables.set('sellerTwoPropertyId', ids[1]);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Property Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/{{sellerOnePropertyId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "properties",
                "{{sellerOnePropertyId}}"
              ]
            },
            "description": "Fetch the detail of an approved property."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Success flag is true', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Property item exists', function () {",
                  "  pm.expect(json?.data?.item).to.be.an('object');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Compare Properties",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/compare?ids={{compareIds}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "properties",
                "compare"
              ],
              "query": [
                {
                  "key": "ids",
                  "value": "{{compareIds}}"
                }
              ]
            },
            "description": "Fetch up to three properties for comparison using property IDs."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Success flag is true', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "const items = Array.isArray(json?.data?.items) ? json.data.items : [];",
                  "pm.test('Compare returns at most 3 items', function () {",
                  "  pm.expect(items.length).to.be.at.most(3);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
