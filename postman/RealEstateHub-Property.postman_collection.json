    {
      "name": "Seller",
      "item": [
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seller1AccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{createPropertyTitle}}\",\n  \"description\": \"{{createPropertyDescription}}\",\n  \"type\": \"apartment\",\n  \"purpose\": \"sale\",\n  \"price\": 3500000000,\n  \"area\": 88,\n  \"bedrooms\": 2,\n  \"bathrooms\": 2,\n  \"address\": \"12 Demo Street, Ha Noi\",\n  \"city\": \"Ha Noi\",\n  \"district\": \"Cau Giay\",\n  \"ward\": \"Dich Vong\",\n  \"latitude\": 21.029,\n  \"longitude\": 105.782,\n  \"images\": [\n    \"https://images.unsplash.com/photo-1560448204-603b3fc33ddc?auto=format&fit=crop&w=1200&q=80\"\n  ],\n  \"amenities\": [\n    \"Thang may\",\n    \"Bao ve 24/7\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/properties",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "properties"
              ]
            },
            "description": "Create a new property as seller 1."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const timestamp = Date.now();",
                  "pm.collectionVariables.set('createPropertyTitle', `P4-11 Demo Property ${timestamp}`);",
                  "pm.collectionVariables.set('createPropertyDescription', `Demo property created for P4-11 at ${timestamp}. This description is long enough for validation.`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Success flag is true', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "if (json?.data?.item?._id) {",
                  "  pm.collectionVariables.set('ownedPropertyId', json.data.item._id);",
                  "}",
                  "if (json?.data?.item?.title) {",
                  "  pm.collectionVariables.set('ownedPropertyTitle', json.data.item.title);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Own Property",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{seller1AccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{updateOwnedPropertyTitle}}\",\n  \"price\": 3650000000,\n  \"area\": 90,\n  \"description\": \"Updated demo property description for P4-11. This text is long enough for validation.\",\n  \"images\": [\n    \"https://images.unsplash.com/photo-1560448204-603b3fc33ddc?auto=format&fit=crop&w=1200&q=80\",\n    \"https://images.unsplash.com/photo-1502672023488-70e25813eb80?auto=format&fit=crop&w=1200&q=80\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/properties/{{ownedPropertyId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "properties",
                "{{ownedPropertyId}}"
              ]
            },
            "description": "Update the property created by seller 1."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('updateOwnedPropertyTitle', 'P4-11 Updated Demo Property');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Success flag is true', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Property remains pending after seller edit', function () {",
                  "  pm.expect(json?.data?.item?.status).to.eql('pending');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Own Property",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{seller1AccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/properties/{{ownedPropertyId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "properties",
                "{{ownedPropertyId}}"
              ]
            },
            "description": "Delete the property created by seller 1."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Success flag is true', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "if (json?.data?.item?._id) {",
                  "  pm.test('Deleted property id matches', function () {",
                  "    pm.expect(String(json.data.item._id)).to.eql(String(pm.collectionVariables.get('ownedPropertyId')));",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
