              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Refresh returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('New access token is returned', function () {",
