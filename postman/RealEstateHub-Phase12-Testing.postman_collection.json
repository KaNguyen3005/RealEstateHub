    {
      "name": "01 - Auth and Setup",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Login with the seeded admin account and store adminToken."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Admin token is returned', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('adminToken', json.data.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Seller",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sellerEmail}}\",\n  \"password\": \"{{sellerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Login with the seeded seller account and store sellerToken."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Seller login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Seller token is returned', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "});",
