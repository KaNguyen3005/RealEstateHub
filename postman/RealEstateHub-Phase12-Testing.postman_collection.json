              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Buyer login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Buyer token is returned', function () {",
