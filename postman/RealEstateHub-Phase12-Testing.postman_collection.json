                ]
              }
            }
          ]
        },
        {
          "name": "T-01 Register Generated User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const email = `phase12.${Date.now()}@realestatehub.local`;",
                  "pm.collectionVariables.set('phase12Email', email);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Generated user is created', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.user.email).to.eql(pm.collectionVariables.get('phase12Email'));",
                  "});",
                  "pm.collectionVariables.set('generatedUserId', json.data.user._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Phase 12 Test User\",\n  \"email\": \"{{phase12Email}}\",\n  \"password\": \"{{phase12Password}}\",\n  \"role\": \"user\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "T-01: Register with valid generated data."
          }
        },
        {
          "name": "T-02 Register Duplicate Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Phase 12 Duplicate User\",\n  \"email\": \"{{phase12Email}}\",\n  \"password\": \"{{phase12Password}}\",\n  \"role\": \"user\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "T-02: Register with the same generated email and expect conflict."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Duplicate register returns 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Duplicate register fails', function () {",
                  "  pm.expect(json.success).to.eql(false);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Block Generated User For T-04",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"blocked\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/users/{{generatedUserId}}/status",
            "description": "Prepare T-04 by blocking the generated user only."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Block generated user returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Generated user status is blocked', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.item.status).to.eql('blocked');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "T-04 Login Blocked User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{phase12Email}}\",\n  \"password\": \"{{phase12Password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "T-04: Login with blocked user should be rejected."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Blocked login returns 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Blocked login fails', function () {",
                  "  pm.expect(json.success).to.eql(false);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
