          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Me returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Current user is returned', function () {",
