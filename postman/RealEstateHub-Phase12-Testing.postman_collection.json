    {
      "name": "02 - Property APIs",
      "item": [
        {
          "name": "T-11 Search Approved Properties",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/properties?limit=10",
            "description": "T-11: Search approved properties and save the first approved property id."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Search returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Only approved properties are returned', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.items).to.be.an('array');",
                  "  json.data.items.forEach((item) => pm.expect(item.status).to.eql('approved'));",
                  "});",
                  "if (json.data.items[0]?._id) {",
                  "  pm.collectionVariables.set('approvedPropertyId', json.data.items[0]._id);",
                  "}"
                ]
              }
            }
          ]
        },
