            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Phase 12 Pending Property {{$timestamp}}\",\n  \"description\": \"A valid Phase 12 property created by the seller to verify pending moderation workflow.\",\n  \"type\": \"apartment\",\n  \"purpose\": \"sale\",\n  \"price\": 3200000000,\n  \"area\": 88,\n  \"bedrooms\": 2,\n  \"bathrooms\": 2,\n  \"address\": \"12 Testing Street, Cau Giay\",\n  \"city\": \"Ha Noi\",\n  \"district\": \"Cau Giay\",\n  \"ward\": \"Dich Vong\",\n  \"latitude\": 21.036,\n  \"longitude\": 105.782,\n  \"images\": [\n    \"https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=1200&q=80\"\n  ],\n  \"amenities\": [\"Balcony\", \"Security\"]\n}"
            },
            "url": "{{baseUrl}}/api/properties",
            "description": "T-07: Seller creates a property and it should be pending."
