            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"{{approvedPropertyId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/conversations",
            "description": "T-13: Conversation should derive sellerId from property.ownerId instead of trusting client input."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create conversation returns 200 or 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Conversation has property and two participants', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.item.propertyId._id).to.eql(pm.collectionVariables.get('approvedPropertyId'));",
                  "  pm.expect(json.data.item.participants).to.have.length(2);",
                  "});",
                  "pm.collectionVariables.set('conversationId', json.data.item._id);"
                ]
              }
            }
          ]
        }
